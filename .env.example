# ═══════════════════════════════════════════════════════
#  LANGGRAPH CHATBOT — API KEYS TEMPLATE
#  Sao chep file nay thanh ".env" roi dien key thuc vao
#  Lenh: copy .env.example .env   (Windows)
#         cp .env.example .env    (Mac/Linux)
# ═══════════════════════════════════════════════════════

# [BAT BUOC] Anthropic API Key — de chay LLM Claude
# Lay tai: https://console.anthropic.com -> API Keys -> Create Key
# Dang ky lan dau nhan $5 credit mien phi
ANTHROPIC_API_KEY=your-anthropic-key-here

# [TUY CHON] Tavily Search Key — de tim kiem web that
# Neu bo trong, chatbot dung Knowledge Base noi bo
# Lay tai: https://app.tavily.com (free: 1000 req/thang)
TAVILY_API_KEY=your-tavily-key-here

# ═══════════════════════════════════════════════════════
#  BAO MAT: Them ".env" vao .gitignore!
#  echo ".env" >> .gitignore
# ═══════════════════════════════════════════════════════
